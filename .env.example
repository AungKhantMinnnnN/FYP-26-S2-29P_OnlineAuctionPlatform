# Core Backend
BACKEND_DATABASE_URL=postgresql://postgres:postgres@db:5432/auction_db
BACKEND_REDIS_URL=redis://redis:6379/0
BACKEND_SECRET_KEY=generate-a-strong-secret-key
BACKEND_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Bidding Engine
BIDDING_REDIS_URL=redis://redis:6379/1
BIDDING_BACKEND_URL=http://backend:8000
BIDDING_SECRET_KEY=another-strong-secret-key

# Recommendation Engine
REC_REDIS_URL=redis://redis:6379/0
REC_BACKEND_URL=http://backend:8000

# Logging
LOG_DIR=/app/logs
HOST_LOG_DIR=./logs

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auction_db
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
